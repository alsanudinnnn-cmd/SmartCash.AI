# Salin fail ini sebagai .dev.vars dan masukkan kunci daripada Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key

# Pilihan: gunakan model lain yang menyokong input imej dan structured output.
GEMINI_MODEL=gemini-3.6-flash

# Resend untuk kod pengesahan e-mel. Gunakan alamat daripada domain yang telah
# anda sahkan dalam Resend, contohnya SmartCash AI <noreply@domainanda.com>.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL="SmartCash AI <noreply@yourdomain.com>"
